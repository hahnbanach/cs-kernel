# {{ company_prog_name }} — copy to ~/.{{ company_slug }}-cs/.env (preferred) or a repo-local .env.
# NEVER commit real values. manifest.toml carries the NON-secret config
# (identity, adapters, scope, knobs); this file holds only SECRETS, the
# privacy SELF_* lists, and the real account uids. Env layers, later wins:
#   {% if platform_env_path %}{{ platform_env_path }}  ->  {% endif %}~/.{{ company_slug }}-cs/.env  ->  repo .env  ->  process env
# --- mailbox app password (Gmail Drafts IMAP append + fixed-template cs-SMTP) ---
EMAIL_PASSWORD=

# --- engine session (the body; Claude Code is the brain) ---
# Public web API key of the engine's Firebase project — exchanges the
# SA-minted custom token for an ID token.
FIREBASE_WEB_API_KEY=
# Real account uids. manifest [engine.accounts] carries the NAMES; the real
# uids live HERE, and ONLY this project's mail domain ever appears.
# Registry format name:uid,... Prefer the mailbox address as the name
# (never a bare first name — Mario has multiple addresses across domains).
# Example: {% for name in accounts %}{{ name }}:<uid>{% if not loop.last %},{% endif %}{% endfor +%}
CS_ACCOUNTS=
# Optional overrides (else the manifest's [engine] values / slug defaults):
#CS_ENGINE_OWNER_UID=
#FIREBASE_SA_PATH=~/.{{ company_slug }}-cs/firebase-sa.json

# --- operator's own accounts to NEVER contact (privacy; comma-separated) ---
SELF_UIDS=
SELF_EMAILS=
{% if crm_adapter == 'shopify' and crm_shopify %}
# --- Shopify CRM ({{ crm_shopify.env_prefix }}_*) — Admin GraphQL, client-credentials grant.
#     Store creds live in {{ platform_env_path }}, not here.
{{ crm_shopify.env_prefix }}_STORE_DOMAIN=
{{ crm_shopify.env_prefix }}_CLIENT_ID=
{{ crm_shopify.env_prefix }}_SECRET=
#{{ crm_shopify.env_prefix }}_ADMIN_TOKEN=      # optional static token (wins over client-credentials)
{% endif %}
{% if sms_enabled %}

# --- SMS proxy ({{ sms_proxy_base }}) — which business is billed ---
SMS_BUSINESS_ID=
{% endif %}

# --- optional runtime overrides (manifest sets the defaults) ---
#CS_TRIAGE_MODE={{ cs_triage_mode }}
#CS_DRIVE={{ drive_scope }}

